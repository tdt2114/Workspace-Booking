{
  "name": "workspace-booking",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:web": "npm run dev --workspace web",
    "dev:final": "npm run dev --workspace web-final -- --port 3002",
    "dev:api": "npm run start:dev --workspace api",
    "build:web": "npm run build --workspace web",
    "build:final": "npm run build --workspace web-final",
    "build:api": "npm run build --workspace api",
    "lint:web": "npm run lint --workspace web",
    "lint:api": "npm run lint --workspace api",
    "test:api": "npm run test --workspace api",
    "test:e2e:api": "npm run test:e2e --workspace api",
    "test:e2e:web": "npm run test:e2e --workspace web"
  }
}
