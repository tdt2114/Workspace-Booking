NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Use /api when web-final is served through the Next.js proxy/tunnel.
# Use http://localhost:3001 only for direct local browser-to-API testing.
NEXT_PUBLIC_API_BASE_URL=/api

# Next.js rewrite target for /api/:path*.
API_PROXY_TARGET=http://127.0.0.1:3001

# Optional Playwright web-final E2E settings.
E2E_BASE_URL_FINAL=http://localhost:3002
E2E_API_URL=http://localhost:3001
E2E_PASSWORD=12345678
E2E_EMPLOYEE_EMAIL=employee@demo.com
E2E_MANAGER_EMAIL=manager@demo.com
E2E_ADMIN_EMAIL=admin@demo.com
